@model OkulSistemi.Models.Kullanici

<div class="container mt-5" style="max-width: 400px;">
    <div class="card shadow p-4">
        <h2 class="text-center text-primary">Kayıt Ol</h2>
        <form asp-action="Kayit" method="post">
            <div class="mb-3">
                <label>Ad Soyad:</label>
                <input asp-for="AdSoyad" class="form-control" />
                <span asp-validation-for="AdSoyad" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label>E-posta:</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label>Şifre:</label>
                <input asp-for="Sifre" type="password" class="form-control" />
                <span asp-validation-for="Sifre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label>Rolünüz:</label>
                <select asp-for="Rol" class="form-select">
                    <option value="Öğrenci">Öğrenci</option>
                    <option value="Öğretmen">Öğretmen</option>
                    <option value="Yönetici">Yönetici</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary w-100">KAYDOL</button>
        </form>
    </div>
</div>
